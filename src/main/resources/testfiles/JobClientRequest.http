POST {{host}}/api/jobs
Authorization: Basic info@osta.gov.et osta@123
Content-Type: application/json

{
  "title": "Senior Data Scientist",
  "position": "Sr. Data Scientist",
  "location": "Addis Ababa",
  "jobType": "FULL_TIME",
  "description": "We are seeking a talented Data Scientist to join our AI research team. You will analyze large datasets, build predictive models, and develop machine learning algorithms. Responsibilities include data preprocessing, feature engineering, model deployment, and presenting insights to stakeholders. Experience with Python, TensorFlow, and SQL is required.",
  "companyName": "DataDriven PLC",
  "salaryMin": 40000,
  "salaryMax": 55000
}


